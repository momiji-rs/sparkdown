{
  "name": "@momiji-rs/sparkdown",
  "version": "0.0.5",
  "description": "Fast, standards-first CommonMark → HTML (100% CommonMark 0.31.2), as WASI-free WebAssembly — zero dependencies, runs in Node/browsers/bundlers/Deno/edge. GitHub Flavored Markdown via the `/gfm` subpath; every extension via `/full`.",
  "type": "module",
  "main": "./sparkdown.mjs",
  "module": "./sparkdown.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./sparkdown.mjs"
    },
    "./gfm": {
      "types": "./gfm.d.ts",
      "default": "./gfm.mjs"
    },
    "./full": {
      "types": "./full.d.ts",
      "default": "./full.mjs"
    }
  },
  "files": ["sparkdown.mjs", "wasm-inline.mjs", "index.d.ts", "gfm.mjs", "gfm-wasm-inline.mjs", "gfm.d.ts", "full.mjs", "full-wasm-inline.mjs", "full.d.ts", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "node build.mjs",
    "test": "node test.mjs"
  },
  "keywords": [
    "markdown",
    "commonmark",
    "html",
    "wasm",
    "webassembly",
    "parser",
    "renderer"
  ],
  "license": "MIT",
  "author": "rubyrs contributors",
  "homepage": "https://github.com/momiji-rs/sparkdown#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/momiji-rs/sparkdown.git",
    "directory": "npm"
  },
  "bugs": {
    "url": "https://github.com/momiji-rs/sparkdown/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
