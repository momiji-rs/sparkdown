{
  "name": "@momiji-rs/sparkdown-gfm",
  "version": "0.0.3",
  "description": "Fast CommonMark + GitHub Flavored Markdown → HTML (strikethrough, task lists, autolinks, tag filter, tables), as WASI-free WebAssembly. Zero dependencies; runs in Node, browsers, bundlers, Deno, and edge runtimes.",
  "type": "module",
  "main": "./sparkdown.mjs",
  "module": "./sparkdown.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./sparkdown.mjs"
    }
  },
  "files": ["sparkdown.mjs", "wasm-inline.mjs", "index.d.ts", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "node build.mjs",
    "test": "node test.mjs"
  },
  "keywords": ["markdown", "commonmark", "gfm", "github", "html", "wasm", "webassembly", "parser", "tables", "strikethrough"],
  "license": "MIT",
  "author": "rubyrs contributors",
  "homepage": "https://github.com/momiji-rs/sparkdown#readme",
  "repository": { "type": "git", "url": "git+https://github.com/momiji-rs/sparkdown.git", "directory": "npm-gfm" },
  "bugs": { "url": "https://github.com/momiji-rs/sparkdown/issues" },
  "engines": { "node": ">=18" }
}
